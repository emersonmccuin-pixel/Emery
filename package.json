{
  "name": "project-commander",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run check:bundle-budgets",
    "check:bundle-budgets": "node ./scripts/check-bundle-budgets.mjs",
    "check:repo-health": "node ./scripts/check-repo-health.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri.ps1 dev",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri.ps1 build",
    "prod:build": "npm run tauri:build",
    "prod:run": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-prod.ps1",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  }
}
