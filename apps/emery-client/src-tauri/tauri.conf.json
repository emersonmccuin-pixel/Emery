{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emery",
  "version": "0.1.0",
  "identifier": "local.euri.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Emery",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
